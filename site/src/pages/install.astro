---
import '../styles/global.css';
import Monitor from 'lucide-astro/Monitor';
import Apple from 'lucide-astro/Apple';
import Terminal from 'lucide-astro/Terminal';
import Download from 'lucide-astro/Download';
import Github from 'lucide-astro/Github';
import BookOpen from 'lucide-astro/BookOpen';
import ArrowLeft from 'lucide-astro/ArrowLeft';
import Copy from 'lucide-astro/Copy';

// Fetch latest release from GitHub API at build time
let release = { tag_name: 'v1.0.0', assets: [] as any[] };
try {
  const res = await fetch('https://api.github.com/repos/cloudboy-jh/glib-code/releases/latest', {
    headers: { 'Accept': 'application/vnd.github+json', 'X-GitHub-Api-Version': '2022-11-28' }
  });
  if (res.ok) release = await res.json();
} catch (e) {
  // fall back to hardcoded
}

const version = release.tag_name;
// asset filenames use the bare semver (no leading `v`)
const ver = version.replace(/^v/, '');

function asset(pattern: RegExp): string {
  const found = release.assets?.find((a: any) => pattern.test(a.name));
  // fallback to hardcoded known URLs
  const base = `https://github.com/cloudboy-jh/glib-code/releases/download/${version}`;
  return found?.browser_download_url ?? `${base}/${pattern.source}`;
}

// resolve each asset URL
const winUrl        = release.assets?.find((a: any) => /Setup.*\.exe$/.test(a.name) && !a.name.endsWith('.blockmap'))?.browser_download_url
                      ?? `https://github.com/cloudboy-jh/glib-code/releases/download/${version}/glib-code-Setup-${ver}.exe`;
const macArmUrl     = release.assets?.find((a: any) => /arm64\.dmg$/.test(a.name))?.browser_download_url
                      ?? `https://github.com/cloudboy-jh/glib-code/releases/download/${version}/glib-code-${ver}-arm64.dmg`;
const linuxAppUrl   = release.assets?.find((a: any) => /\.AppImage$/.test(a.name))?.browser_download_url
                      ?? `https://github.com/cloudboy-jh/glib-code/releases/download/${version}/glib-code-${ver}-x86_64.AppImage`;
const linuxDebUrl   = release.assets?.find((a: any) => /\.deb$/.test(a.name))?.browser_download_url
                      ?? `https://github.com/cloudboy-jh/glib-code/releases/download/${version}/glib-code-${ver}-amd64.deb`;

const winSize       = release.assets?.find((a: any) => /Setup.*\.exe$/.test(a.name) && !a.name.endsWith('.blockmap'))?.size;
const macArmSize    = release.assets?.find((a: any) => /arm64\.dmg$/.test(a.name))?.size;
const linuxAppSize  = release.assets?.find((a: any) => /\.AppImage$/.test(a.name))?.size;
const linuxDebSize  = release.assets?.find((a: any) => /\.deb$/.test(a.name))?.size;

function mb(bytes?: number) {
  if (!bytes) return null;
  return `${(bytes / 1024 / 1024).toFixed(1)} MB`;
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Install · glib-code</title>
    <meta name="description" content="Download glib-code for Windows, Mac, or Linux. Or self-host from source." />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <!-- Apply persisted site theme before paint. Two themes only. -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('glib-theme');
          t = (t === 'minimal-paper') ? 'minimal-paper' : 'minimal-dark';
          document.documentElement.setAttribute('data-theme', t);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'minimal-dark');
        }
      })();
    </script>
  </head>
  <body>

    <div class="min-h-screen flex flex-col">

      <!-- Nav -->
      <nav class="relative z-10 flex items-center justify-between px-8 pt-8 pb-4">
        <a href="/" class="flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors">
          <ArrowLeft size={15} />
          Back
        </a>
        <div class="flex items-center gap-3">
          <a
            href="https://github.com/cloudboy-jh/glib-code"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors"
          >
            <Github size={14} />GitHub
          </a>
          <a
            href="https://glib-code-docs.pages.dev/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors"
          >
            <BookOpen size={14} />Docs
          </a>
        </div>
      </nav>

      <!-- Header -->
      <header class="flex flex-col items-center text-center px-8 pt-16 pb-12 gap-3">
        <span class="text-xs font-mono text-muted-foreground/60 border border-border/50 rounded px-2 py-0.5">{version}</span>
        <h1 class="text-2xl md:text-3xl font-semibold text-foreground tracking-tight">Download glib-code</h1>
        <p class="text-sm text-muted-foreground max-w-xs leading-relaxed">
          Desktop app for Windows, Mac, and Linux. Or run it yourself from source.
        </p>
      </header>

      <!-- Platform cards -->
      <section class="flex flex-col items-center px-8 pb-16">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 w-full max-w-4xl">

          <!-- Windows -->
          <div id="card-win" class="flex flex-col gap-5 rounded-xl border border-border/50 p-6 bg-muted/20 transition-colors">
            <div class="flex items-center gap-3">
              <div class="text-muted-foreground/60"><Monitor size={22} /></div>
              <div>
                <h2 class="text-sm font-semibold text-foreground">Windows</h2>
                <p class="text-xs text-muted-foreground/60 mt-0.5">NSIS installer{mb(winSize) ? ` · ${mb(winSize)}` : ''}</p>
              </div>
            </div>
            <a
              href={winUrl}
              class="inline-flex items-center justify-center gap-2 h-9 px-4 rounded-md
                     bg-primary/90 text-primary-foreground font-medium text-sm
                     hover:bg-primary transition-colors mt-auto"
              style="box-shadow: inset 0 1px 0 hsl(0 0% 100% / 0.08), 0 1px 3px hsl(0 0% 0% / 0.4);"
            >
              <Download size={14} />
              Download .exe
            </a>
          </div>

          <!-- Mac -->
          <div id="card-mac" class="flex flex-col gap-5 rounded-xl border border-border/50 p-6 bg-muted/20 transition-colors">
            <div class="flex items-center gap-3">
              <div class="text-muted-foreground/60"><Apple size={22} /></div>
              <div>
                <h2 class="text-sm font-semibold text-foreground">macOS</h2>
                <p class="text-xs text-muted-foreground/60 mt-0.5">Apple Silicon{mb(macArmSize) ? ` · ${mb(macArmSize)}` : ''}</p>
              </div>
            </div>
            <a
              href={macArmUrl}
              class="inline-flex items-center justify-center gap-2 h-9 px-4 rounded-md
                     bg-primary/90 text-primary-foreground font-medium text-sm
                     hover:bg-primary transition-colors mt-auto"
              style="box-shadow: inset 0 1px 0 hsl(0 0% 100% / 0.08), 0 1px 3px hsl(0 0% 0% / 0.4);"
            >
              <Download size={14} />
              Download .dmg
            </a>
          </div>

          <!-- Linux -->
          <div id="card-linux" class="flex flex-col gap-5 rounded-xl border border-border/50 p-6 bg-muted/20 transition-colors">
            <div class="flex items-center gap-3">
              <div class="text-muted-foreground/60"><Terminal size={22} /></div>
              <div>
                <h2 class="text-sm font-semibold text-foreground">Linux</h2>
                <p class="text-xs text-muted-foreground/60 mt-0.5">x86_64</p>
              </div>
            </div>
            <div class="flex flex-col gap-2 mt-auto">
              <a
                href={linuxAppUrl}
                class="inline-flex items-center justify-center gap-2 h-9 px-4 rounded-md
                       bg-primary/90 text-primary-foreground font-medium text-sm
                       hover:bg-primary transition-colors"
                style="box-shadow: inset 0 1px 0 hsl(0 0% 100% / 0.08), 0 1px 3px hsl(0 0% 0% / 0.4);"
              >
                <Download size={14} />
                Download .AppImage
              </a>
              <a
                href={linuxDebUrl}
                class="inline-flex items-center justify-center gap-2 h-9 px-4 rounded-md
                       border border-border text-muted-foreground font-medium text-sm
                       hover:text-foreground hover:border-border/80 transition-colors"
              >
                <Download size={14} />
                Download .deb
              </a>
            </div>
          </div>

        </div>
      </section>

      <!-- Divider -->
      <div class="flex items-center gap-4 px-8 max-w-4xl mx-auto w-full pb-12">
        <div class="flex-1 h-px bg-border/40"></div>
        <span class="text-xs text-muted-foreground/40 font-mono">or</span>
        <div class="flex-1 h-px bg-border/40"></div>
      </div>

      <!-- Self-host -->
      <section class="flex flex-col items-center px-8 pb-32 gap-6">
        <div class="w-full max-w-4xl flex flex-col gap-4">
          <div>
            <h2 class="text-base font-semibold text-foreground tracking-tight">Self-host</h2>
            <p class="text-sm text-muted-foreground mt-1 leading-relaxed">
              Run the full stack locally. Requires <a href="https://bun.sh" target="_blank" rel="noopener noreferrer" class="text-foreground/70 hover:text-foreground underline underline-offset-2 transition-colors">Bun</a>, Git, and a provider API key.
            </p>
          </div>

          <div class="relative rounded-xl border border-border/50 bg-muted/20 overflow-hidden">
            <div class="flex items-center justify-between px-4 py-2.5 border-b border-border/30">
              <span class="text-xs font-mono text-muted-foreground/50">terminal</span>
              <button
                id="copy-btn"
                class="flex items-center gap-1.5 text-xs text-muted-foreground/50 hover:text-muted-foreground transition-colors"
                aria-label="Copy to clipboard"
              >
                <Copy size={12} />
                <span id="copy-label">Copy</span>
              </button>
            </div>
            <pre class="px-5 py-4 text-sm font-mono text-foreground/80 leading-7 overflow-x-auto"><code><span class="text-muted-foreground/50"># clone and install</span>
git clone https://github.com/cloudboy-jh/glib-code.git
cd glib-code
bun install

<span class="text-muted-foreground/50"># run the full stack (server + web)</span>
bun run dev</code></pre>
          </div>

          <p class="text-xs text-muted-foreground/50 leading-relaxed">
            App runs at <span class="font-mono text-muted-foreground/70">http://localhost:5173</span>. Add a provider API key under Settings → Models before starting an agent session.
          </p>
        </div>
      </section>

    </div>

    <footer class="fixed bottom-0 left-0 right-0 p-6 text-sm text-muted-foreground flex justify-between items-center">
      <span>© 2026 glib-code</span>
      <a
        href="https://twitter.com/Jackhortonlol"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-foreground transition-colors"
      >
        @Jackhortonlol
      </a>
    </footer>

    <script>
      // OS detection — highlight the matching card
      const ua = navigator.userAgent;
      let detected: 'win' | 'mac' | 'linux' | null = null;
      if (/Windows/i.test(ua)) detected = 'win';
      else if (/Mac OS X/i.test(ua)) detected = 'mac';
      else if (/Linux/i.test(ua)) detected = 'linux';

      if (detected) {
        const card = document.getElementById(`card-${detected}`);
        if (card) {
          card.classList.add('border-primary/40', 'bg-primary/5');
          card.classList.remove('border-border/50', 'bg-muted/20');
          // add a subtle "Recommended for your OS" badge
          const badge = document.createElement('span');
          badge.textContent = 'Your OS';
          badge.className = 'absolute top-3 right-3 text-xs font-mono text-primary/70 border border-primary/30 rounded px-1.5 py-0.5';
          card.style.position = 'relative';
          card.prepend(badge);
        }
      }

      // Copy button
      const btn = document.getElementById('copy-btn') as HTMLButtonElement;
      const lbl = document.getElementById('copy-label') as HTMLElement;
      btn.addEventListener('click', async () => {
        await navigator.clipboard.writeText(
          'git clone https://github.com/cloudboy-jh/glib-code.git\ncd glib-code\nbun install\n\nbun run dev'
        );
        lbl.textContent = 'Copied!';
        setTimeout(() => { lbl.textContent = 'Copy'; }, 2000);
      });
    </script>

  </body>
</html>
