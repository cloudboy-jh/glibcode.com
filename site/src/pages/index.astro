---
import '../styles/global.css';
import Github from 'lucide-astro/Github';
import BookOpen from 'lucide-astro/BookOpen';
import ChevronDown from 'lucide-astro/ChevronDown';
import FolderOpen from 'lucide-astro/FolderOpen';
import Bot from 'lucide-astro/Bot';
import GitCompare from 'lucide-astro/GitCompare';
import Box from 'lucide-astro/Box';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>glib-code</title>
    <meta name="description" content="A workspace where agents code in a sandbox. Your real code stays untouched until you approve." />
    <meta property="og:title" content="glib-code" />
    <meta property="og:description" content="A workspace where agents code in a sandbox. Your real code stays untouched until you approve." />
    <meta property="og:image" content="/icon.png" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <!-- Apply persisted theme before paint to avoid FOUC. Two themes only. -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('glib-theme');
          t = (t === 'minimal-paper') ? 'minimal-paper' : 'minimal-dark';
          document.documentElement.setAttribute('data-theme', t);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'minimal-dark');
        }
      })();
    </script>
  </head>
  <body>

    <!-- Header with site theme toggle -->
    <header class="fixed top-0 left-0 right-0 z-20 p-6 flex justify-end items-center">
      <div
        role="group"
        aria-label="Site theme"
        class="inline-flex items-center rounded-md border border-border/60 p-1 gap-1 bg-background/40 backdrop-blur-sm"
      >
        <button
          data-theme-set="minimal-dark"
          aria-pressed="true"
          class="theme-pill px-2.5 h-7 rounded text-xs font-medium text-muted-foreground hover:text-foreground transition-colors"
        >
          Dark
        </button>
        <button
          data-theme-set="minimal-paper"
          aria-pressed="false"
          class="theme-pill px-2.5 h-7 rounded text-xs font-medium text-muted-foreground hover:text-foreground transition-colors"
        >
          Paper
        </button>
      </div>
    </header>

    <!-- Hero section -->
    <section class="min-h-screen flex flex-col items-center justify-center gap-6 p-8 relative">

      <!-- Hero icon -->
      <div class="relative icon-hero">
        <div
          class="absolute inset-0 rounded-3xl blur-2xl scale-75 translate-y-6 opacity-30"
          style="background: radial-gradient(ellipse at center, hsl(var(--glow)) 0%, transparent 70%);"
          aria-hidden="true"
        ></div>
        <img
          src="/icon.png"
          alt=""
          class="relative h-36 md:h-44 select-none drop-shadow-2xl"
          draggable="false"
          aria-hidden="true"
        />
      </div>

      <!-- Wordmark -->
      <img
        src="/glibcode-wordmark.png"
        alt="glib-code"
        class="h-9 md:h-11 select-none opacity-90"
        draggable="false"
      />

      <!-- Tagline -->
      <p class="text-muted-foreground text-sm md:text-base text-center max-w-sm leading-relaxed tracking-wide">
        A workspace where agents code in a sandbox.<br />Your real code stays untouched until you approve.
      </p>

      <!-- Buttons -->
      <div class="flex items-center gap-3 flex-wrap justify-center pt-1">

        <a
          href="/install"
          class="inline-flex items-center justify-center h-9 px-4 rounded-md
                 text-muted-foreground font-medium text-sm
                 border border-border
                 hover:text-foreground hover:border-border/80 transition-colors"
        >
          Download
        </a>

        <a
          href="https://github.com/cloudboy-jh/glib-code"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center h-9 px-4 rounded-md
                 bg-primary/90 text-primary-foreground font-medium text-sm
                 hover:bg-primary
                 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background
                 transition-colors"
          style="box-shadow: inset 0 1px 0 hsl(0 0% 100% / 0.08), 0 1px 3px hsl(0 0% 0% / 0.4);"
        >
          <Github size={15} class="mr-1.5" />GitHub
        </a>

        <a
          href="https://glib-code-docs.pages.dev/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center h-9 px-4 rounded-md
                 bg-primary/90 text-primary-foreground font-medium text-sm
                 hover:bg-primary
                 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background
                 transition-colors"
          style="box-shadow: inset 0 1px 0 hsl(0 0% 100% / 0.08), 0 1px 3px hsl(0 0% 0% / 0.4);"
        >
          <BookOpen size={15} class="mr-1.5" />Docs
        </a>

      </div>

      <!-- Screenshots -->
      <div class="flex gap-4 w-full max-w-5xl mt-6 px-2">
        <button
          data-modal-src="/screenshots/session-v2.png"
          data-modal-alt="glib-code session view"
          class="flex-1 rounded-lg overflow-hidden border border-border/50 shadow-2xl cursor-zoom-in
                 hover:border-border transition-colors group"
          style="aspect-ratio: 16/10;"
        >
          <img src="/screenshots/session-v2.png" alt="glib-code session view" class="w-full h-full object-cover object-top group-hover:opacity-90 transition-opacity" draggable="false" />
        </button>
        <button
          data-modal-src="/screenshots/diffs.png"
          data-modal-alt="glib-code diff review"
          class="flex-1 rounded-lg overflow-hidden border border-border/50 shadow-2xl cursor-zoom-in
                 hover:border-border transition-colors group"
          style="aspect-ratio: 16/10;"
        >
          <img src="/screenshots/diffs.png" alt="glib-code diff review" class="w-full h-full object-cover object-center group-hover:opacity-90 transition-opacity" draggable="false" />
        </button>
      </div>

      <!-- Chevron -->
      <button
        id="scroll-chevron"
        aria-label="Scroll to features"
        class="mt-10 text-muted-foreground/40 hover:text-muted-foreground transition-colors chevron-bounce"
      >
        <ChevronDown size={24} />
      </button>

    </section>

    <!-- Features section -->
    <section id="features" class="flex flex-col items-center px-8 pt-32 pb-40">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-3xl w-full">

        <!-- Repo Picker -->
        <div class="flex flex-col gap-3 rounded-xl border border-border/50 bg-muted/20 p-6 transition-colors hover:border-border/80">
          <div class="text-muted-foreground/60">
            <FolderOpen size={24} />
          </div>
          <h3 class="text-lg font-semibold text-foreground tracking-tight">Local repos, no upload</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            Open any Git repo on your machine and inspect history and working changes before the agent touches a file.
          </p>
        </div>

        <!-- Session -->
        <div class="flex flex-col gap-3 rounded-xl border border-border/50 bg-muted/20 p-6 transition-colors hover:border-border/80">
          <div class="text-muted-foreground/60">
            <Bot size={24} />
          </div>
          <h3 class="text-lg font-semibold text-foreground tracking-tight">Bring your own model</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            Prompt the agent and watch it work in real time. Bring your own provider key: Anthropic, OpenAI, or anything else.
          </p>
        </div>

        <!-- Diffs -->
        <div class="flex flex-col gap-3 rounded-xl border border-border/50 bg-muted/20 p-6 transition-colors hover:border-border/80">
          <div class="text-muted-foreground/60">
            <GitCompare size={24} />
          </div>
          <h3 class="text-lg font-semibold text-foreground tracking-tight">Approve every line</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            Full side-by-side diffs of every file the agent touched. Nothing lands in your repo until you've read every line.
          </p>
        </div>

        <!-- Gittrix -->
        <div class="flex flex-col gap-3 rounded-xl border border-border/50 bg-muted/20 p-6 transition-colors hover:border-border/80">
          <div class="text-muted-foreground/60">
            <Box size={24} />
          </div>
          <h3 class="text-lg font-semibold text-foreground tracking-tight">Sandboxed by default</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            Every session runs in an isolated{' '}
            <a href="https://gittrix.com/" target="_blank" rel="noopener noreferrer" class="text-foreground/80 hover:text-foreground underline underline-offset-2 transition-colors">Gittrix</a>{' '}
            sandbox. Promote only the files you want. Nothing touches your repo until you do.
          </p>
        </div>

      </div>
    </section>

    <!-- Themes section -->
    <section id="themes" class="flex flex-col items-center px-8 pt-32 pb-40 gap-10">

      <!-- Themes hero -->
      <div class="flex flex-col items-center gap-4 text-center max-w-xl">
        <span class="text-xs font-mono text-muted-foreground/60 border border-border/50 rounded px-2 py-0.5">house themes</span>
        <h2 class="text-2xl md:text-3xl font-semibold text-foreground tracking-tight">
          <!-- TODO: final headline copy -->
          Two favorites. A whole catalog.
        </h2>
        <p class="text-sm md:text-base text-muted-foreground leading-relaxed max-w-sm">
          <!-- TODO: final subcopy -->
          Minimal Dark and Minimal Paper are glib's house pair: a matched screen-and-paper set we designed in-house and ship up front. They're the face of a full theme catalog inside the editor, and it keeps growing. Toggle below to reskin this page live.
        </p>
      </div>

      <!-- Featured theme toggle (binary) -->
      <div
        role="group"
        aria-label="Site theme"
        class="inline-flex items-center rounded-md border border-border/60 p-1 gap-1"
      >
        <button
          data-theme-set="minimal-dark"
          aria-pressed="true"
          class="theme-pill px-3 h-8 rounded text-xs font-medium text-muted-foreground hover:text-foreground transition-colors"
        >
          Minimal Dark
        </button>
        <button
          data-theme-set="minimal-paper"
          aria-pressed="false"
          class="theme-pill px-3 h-8 rounded text-xs font-medium text-muted-foreground hover:text-foreground transition-colors"
        >
          Minimal Paper
        </button>
      </div>

      <!-- Toggle helper text -->
      <p class="text-xs text-muted-foreground/60 text-center max-w-sm">
        Site preview shows our two house themes. The full catalog lives in the editor.{' '}
        {/* TODO: wire real catalog/app URL */}
        <a
          href="#"
          class="text-foreground/80 hover:text-foreground underline underline-offset-2 transition-colors"
        >
          browse in glib ↗
        </a>
      </p>

      <!-- Side-by-side preview of the glib review surface in both themes -->
      <h2 class="sr-only">Side-by-side preview of the glib review surface in the Minimal Dark theme and the Minimal Paper theme, with base ramp and accent swatches for each.</h2>
      <div class="w-full max-w-3xl" style="display:grid; grid-template-columns:repeat(auto-fit,minmax(290px,1fr)); gap:14px; font-family:'DM Sans',system-ui,sans-serif;">

        <!-- Minimal Dark preview -->
        <div>
          <div class="text-muted-foreground" style="font-size:12px; letter-spacing:.04em; margin:0 0 8px 2px; text-transform:uppercase;">Minimal Dark</div>
          <div style="background:#161616; border:1px solid #262626; border-radius:8px; overflow:hidden;">
            <div style="display:flex; align-items:center; gap:8px; padding:10px 12px; border-bottom:1px solid #262626;">
              <span style="width:8px; height:8px; border-radius:50%; background:#E6E6E6;"></span>
              <span style="font-size:13px; color:#E6E6E6; font-weight:500;">glib · review</span>
              <span style="margin-left:auto; font-size:12px; color:#7A7873; font-family:ui-monospace,'DM Mono',monospace;">feat/warm-light</span>
            </div>
            <div style="padding:8px 12px; font-family:ui-monospace,'DM Mono',SFMono-Regular,monospace; font-size:12px; line-height:1.7;">
              <div style="color:#7A7873;">src/theme/tokens.ts</div>
              <div style="color:#8C8A85;">  export const surface = {'{'}</div>
              <div style="background:rgba(209,77,65,.13); color:#D14D41;">-&nbsp;&nbsp;bg: "#000000",</div>
              <div style="background:rgba(135,154,57,.13); color:#879A39;">+&nbsp;&nbsp;bg: "#0D0D0D",</div>
              <div style="color:#8C8A85;">  {'}'}</div>
            </div>
            <div style="display:flex; gap:8px; padding:10px 12px; border-top:1px solid #262626;">
              <button style="margin-left:auto; font-size:12px; padding:5px 12px; border-radius:5px; border:1px solid #2E2E2E; background:transparent; color:#B5B3AD;">Discard</button>
              <button style="font-size:12px; padding:5px 12px; border-radius:5px; border:1px solid #E6E6E6; background:#E6E6E6; color:#0D0D0D; font-weight:500;">Promote</button>
            </div>
          </div>
          <div style="display:flex; gap:4px; margin-top:8px; align-items:center;">
            <span style="width:20px;height:14px;border-radius:3px;border:1px solid #2A2A2A;background:#0D0D0D;"></span>
            <span style="width:20px;height:14px;border-radius:3px;background:#161616;"></span>
            <span style="width:20px;height:14px;border-radius:3px;background:#262626;"></span>
            <span style="width:20px;height:14px;border-radius:3px;background:#7A7873;"></span>
            <span style="width:20px;height:14px;border-radius:3px;background:#E6E6E6;"></span>
            <span style="width:1px;height:14px;background:#333; margin:0 4px;"></span>
            <span style="width:14px;height:14px;border-radius:50%;background:#D14D41;"></span>
            <span style="width:14px;height:14px;border-radius:50%;background:#DA702C;"></span>
            <span style="width:14px;height:14px;border-radius:50%;background:#879A39;"></span>
            <span style="width:14px;height:14px;border-radius:50%;background:#3AA99F;"></span>
            <span style="width:14px;height:14px;border-radius:50%;background:#4385BE;"></span>
            <span style="width:14px;height:14px;border-radius:50%;background:#8B7EC8;"></span>
            <span class="text-muted-foreground/50" style="font-size:11px; margin-left:4px; font-family:ui-monospace,monospace;">400s</span>
          </div>
        </div>

        <!-- Minimal Paper preview -->
        <div>
          <div class="text-muted-foreground" style="font-size:12px; letter-spacing:.04em; margin:0 0 8px 2px; text-transform:uppercase;">Minimal Paper</div>
          <div style="background:#F2F0E5; border:1px solid #CECDC3; border-radius:8px; overflow:hidden;">
            <div style="display:flex; align-items:center; gap:8px; padding:10px 12px; background:#FFFCF0; border-bottom:1px solid #CECDC3;">
              <span style="width:8px; height:8px; border-radius:50%; background:#100F0F;"></span>
              <span style="font-size:13px; color:#100F0F; font-weight:500;">glib · review</span>
              <span style="margin-left:auto; font-size:12px; color:#878580; font-family:ui-monospace,'DM Mono',monospace;">feat/warm-light</span>
            </div>
            <div style="padding:8px 12px; background:#FFFCF0; font-family:ui-monospace,'DM Mono',SFMono-Regular,monospace; font-size:12px; line-height:1.7;">
              <div style="color:#878580;">src/theme/tokens.ts</div>
              <div style="color:#575653;">  export const surface = {'{'}</div>
              <div style="background:#FFE1D5; color:#AF3029;">-&nbsp;&nbsp;bg: "#000000",</div>
              <div style="background:#EDEECF; color:#66800B;">+&nbsp;&nbsp;bg: "#0D0D0D",</div>
              <div style="color:#575653;">  {'}'}</div>
            </div>
            <div style="display:flex; gap:8px; padding:10px 12px; background:#FFFCF0; border-top:1px solid #CECDC3;">
              <button style="margin-left:auto; font-size:12px; padding:5px 12px; border-radius:5px; border:1px solid #B7B5AC; background:transparent; color:#575653;">Discard</button>
              <button style="font-size:12px; padding:5px 12px; border-radius:5px; border:1px solid #100F0F; background:#100F0F; color:#FFFCF0; font-weight:500;">Promote</button>
            </div>
          </div>
          <div style="display:flex; gap:4px; margin-top:8px; align-items:center;">
            <span style="width:20px;height:14px;border-radius:3px;border:1px solid #CECDC3;background:#FFFCF0;"></span>
            <span style="width:20px;height:14px;border-radius:3px;background:#F2F0E5;"></span>
            <span style="width:20px;height:14px;border-radius:3px;background:#E6E4D9;"></span>
            <span style="width:20px;height:14px;border-radius:3px;background:#878580;"></span>
            <span style="width:20px;height:14px;border-radius:3px;background:#100F0F;"></span>
            <span style="width:1px;height:14px;background:#CECDC3; margin:0 4px;"></span>
            <span style="width:14px;height:14px;border-radius:50%;background:#AF3029;"></span>
            <span style="width:14px;height:14px;border-radius:50%;background:#BC5215;"></span>
            <span style="width:14px;height:14px;border-radius:50%;background:#66800B;"></span>
            <span style="width:14px;height:14px;border-radius:50%;background:#24837B;"></span>
            <span style="width:14px;height:14px;border-radius:50%;background:#205EA6;"></span>
            <span style="width:14px;height:14px;border-radius:50%;background:#5E409D;"></span>
            <span class="text-muted-foreground/50" style="font-size:11px; margin-left:4px; font-family:ui-monospace,monospace;">600s</span>
          </div>
        </div>

      </div>

    </section>

    <!-- Modal -->
    <div
      id="modal"
      class="fixed inset-0 z-50 flex items-center justify-center p-8"
      style="display: none;"
      role="dialog"
      aria-modal="true"
      aria-label="Screenshot preview"
    >
      <div id="modal-backdrop" class="absolute inset-0 bg-black/80 backdrop-blur-sm"></div>
      <div class="relative z-10 max-w-6xl w-full">
        <button
          id="modal-close"
          class="absolute -top-10 right-0 text-muted-foreground hover:text-foreground transition-colors text-sm"
          aria-label="Close"
        >
          ESC to close
        </button>
        <img
          id="modal-img"
          src=""
          alt=""
          class="w-full rounded-lg border border-border/50 shadow-2xl"
          draggable="false"
        />
      </div>
    </div>

    <footer class="fixed bottom-0 left-0 right-0 p-6 text-sm text-muted-foreground flex justify-between items-center">
      <span>© 2026 glib-code</span>
      <a
        href="https://twitter.com/Jackhortonlol"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-foreground transition-colors"
      >
        @Jackhortonlol
      </a>
    </footer>

    <script>
      const modal = document.getElementById('modal') as HTMLElement;
      const modalImg = document.getElementById('modal-img') as HTMLImageElement;
      const modalBackdrop = document.getElementById('modal-backdrop') as HTMLElement;
      const modalClose = document.getElementById('modal-close') as HTMLElement;

      function openModal(src: string, alt: string) {
        modalImg.src = src;
        modalImg.alt = alt;
        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
      }

      function closeModal() {
        modal.style.display = 'none';
        document.body.style.overflow = '';
      }

      document.querySelectorAll<HTMLButtonElement>('[data-modal-src]').forEach(btn => {
        btn.addEventListener('click', () => {
          openModal(btn.dataset.modalSrc!, btn.dataset.modalAlt!);
        });
      });

      modalBackdrop.addEventListener('click', closeModal);
      modalClose.addEventListener('click', closeModal);
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeModal();
      });

      // Chevron fade on scroll
      const chevron = document.getElementById('scroll-chevron') as HTMLElement;
      chevron.addEventListener('click', () => {
        document.getElementById('features')!.scrollIntoView({ behavior: 'smooth' });
      });

      window.addEventListener('scroll', () => {
        const scrolled = window.scrollY > 80;
        chevron.style.opacity = scrolled ? '0' : '1';
        chevron.style.pointerEvents = scrolled ? 'none' : 'auto';
      }, { passive: true });

      // ---- Site theme toggle (binary: minimal-dark | minimal-paper) ----
      const ROOT = document.documentElement;
      const STORE = 'glib-theme';
      const THEMES = ['minimal-dark', 'minimal-paper'] as const;
      type Theme = typeof THEMES[number];

      function applyTheme(t: string) {
        const theme: Theme = THEMES.includes(t as Theme) ? (t as Theme) : 'minimal-dark';
        ROOT.setAttribute('data-theme', theme);
        document.querySelectorAll<HTMLButtonElement>('[data-theme-set]').forEach(btn => {
          btn.setAttribute('aria-pressed', String(btn.dataset.themeSet === theme));
        });
      }

      // Sync UI with whatever the head script already applied.
      applyTheme(ROOT.getAttribute('data-theme') || 'minimal-dark');

      document.querySelectorAll<HTMLButtonElement>('[data-theme-set]').forEach(btn => {
        btn.addEventListener('click', () => {
          const t = btn.dataset.themeSet!;
          try { localStorage.setItem(STORE, t); } catch (e) { /* ignore */ }
          applyTheme(t);
        });
      });
    </script>

  </body>
</html>
